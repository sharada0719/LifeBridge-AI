# Google Gemini API key (Required for AI Copilot, Image recognition, Multi-agent reasoning)
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Database Config (Defaults to local SQLite; override with PostgreSQL for Docker deployment)
DATABASE_URL=sqlite:///./lifebridge.db
# DATABASE_URL=postgresql://postgres:lifebridgepassword123@localhost:5432/lifebridge_db

# FastAPI Secret key for JWT security token signing
SECRET_KEY=super-secret-lifebridge-key-change-in-production-1234567890
